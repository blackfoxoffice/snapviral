{
  "expo": {
    "name": "SnapViral",
    "slug": "snapviral-youtube-api-key",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "snapviral",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.newsflow.studio.shell",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "SnapViral may use the camera in some web flows.",
        "NSPhotoLibraryUsageDescription": "SnapViral may access your photos for uploads."
      }
    },
    "android": {
      "package": "com.newsflow.studio.shell",
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": ["expo-splash-screen"],
    "extra": {
      "eas": {
        "projectId": "f623fc30-5cbe-4109-9895-27d1e0a3496a"
      }
    },
    "owner": "blackfoxuser",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
